v2] n=500\n  200/500\n  400/500\nEval [reinforce-pope] n=500\n  200/500\n  400/500\nEval [reinforce-mmbench] n=400\n","output_type":"stream"}],"execution_count":null},{"id":"55704735-5749-45d4-9f98-055681115fe8","cell_type":"code","source":"# CELL 13 — Split Conformal Prediction (core UQ contribution)\n# Tests whether each agent's behaviour supports valid coverage guarantees.\n# Nonconformity score s = 1 - FGM (low FGM = high nonconformity = likely wrong).\n# Calibrate threshold q_hat on calibration split, test coverage on held-out split.\nimport numpy as np\n\nALPHA=CFG[\"CONFORMAL_ALPHA\"]  # 0.1 -> target 90% coverage\ndef split_conformal(scores, alpha=0.1, cal_frac=0.5, seed=0):\n    s=np.array([1.0-x for x in scores])  # nonconformity\n    n=len(s)\n    if n<10: return None\n    rng=np.random.default_rng(seed); idx=rng.permutation(n)\n    n_cal=int(n*cal_frac)\n    cal,test=s[idx[:n_cal]],s[idx[n_cal:]]\n    # conformal quantile\n    q_level=np.ceil((n_cal+1)*(1-alpha))/n_cal\n    q_level=min(q_level,1.0)\n    q_hat=np.quantile(cal,q_level,method=\"higher\")\n    # coverage on test: fraction with nonconformity <= q_hat (i.e., prediction set contains truth)\n    coverage=float(np.mean(test<=q_hat))\n    avg_set_size=float(np.mean(s<=q_hat))  # proxy for set size / efficiency\n    return {\"q_hat\":round(q_hat,4),\"coverage\":round(coverage,4),\n            \"target\":round(1-alpha,4),\"gap\":round(coverage-(1-alpha),4),\n            \"avg_set_size\":round(avg_set_size,4),\"n\":n}\n\nprint(f\"Conformal prediction (target coverage = {1-ALPHA:.0%})\\n\")\nconformal_results={}\nfor bm in [\"scienceqa\",\"vqa_v2\",\"mmbench\",\"textvqa\"]:\n    if bm not in conformal_scores: continue\n    print(f\"\\n{'='*64}\\n{bm.upper()}\\n{'='*64}\")\n    print(f\"  {'Agent':<12}{'Coverage':>10}{'Target':>9}{'Gap':>9}{'SetSize':>9}\")\n    conformal_results[bm]={}\n    for agent in [\"vanilla\",\"reinforce\",\"ppo_clip\",\"hra\"]:\n        seed_scores=conformal_scores[bm].get(agent,{})\n        if not seed_scores: continue\n        # Pool coverage across seeds (each seed = one conformal run)\n        covs,gaps,sizes=[],[],[]\n        for sd,sc in seed_scores.items():\n            res=split_conformal(sc,alpha=ALPHA,seed=sd)\n            if res: covs.append(res[\"coverage\"]); gaps.append(res[\"gap\"]); sizes.append(res[\"avg_set_size\"])\n        if not covs: continue\n        mc,mg,ms=np.mean(covs),np.mean(gaps),np.mean(sizes)\n        conformal_results[bm][agent]={\"coverage_mean\":round(mc,4),\"coverage_std\":round(np.std(covs,ddof=1) if len(covs)>1 else 0,4),\n                                       \"gap_mean\":round(mg,4),\"set_size_mean\":round(ms,4),\"n_seeds\":len(covs)}\n        flag=\"OK\" if abs(mg)<0.05 else \"MISCALIBRATED\"\n        print(f\"  {agent:<12}{mc:>10.4f}{1-ALPHA:>9.2f}{mg:>+9.4f}{ms:>9.4f}  {flag}\")\n\nimport json as _json, os\nwith open(os.path.join(WORK_DIR,\"conformal_results.json\"),\"w\") as f:\n    _json.dump(conformal_results,f,indent=2)\nprint(\"\\nSaved conformal_results.json\")\nprint(\"\\nKEY INSIGHT: An agent is UQ-compatible if coverage approx target with low cross-seed variance.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"cc5ae6cc-d330-4de4-b036-e4bdb3827714","cell_type":"code","source":"# CELL 14 — Conformal Coverage Visualisation\nimport matplotlib.pyplot as plt, numpy as np, os\nbenches=[b for b in [\"scienceqa\",\"vqa_v2\",\"mmbench\",\"textvqa\"] if b in conformal_results and conformal_results[b]]\nagents=[\"vanilla\",\"reinforce\",\"ppo_clip\",\"hra\"]\nLABELS={\"vanilla\":\"Vanilla\",\"reinforce\":\"REINFORCE\",\"ppo_clip\":\"PPO-Clip\",\"hra\":\"HRA-RL\"}\nCOLOURS={\"vanilla\":\"#7F8C8D\",\"reinforce\":\"#C0392B\",\"ppo_clip\":\"#E67E22\",\"hra\":\"#1B6B7B\"}\nfig,axes=plt.subplots(1,len(benches),figsize=(5*len(benches),5),squeeze=False); axes=axes[0]\ntarget=1-CFG[\"CONFORMAL_ALPHA\"]\nfor ax,bm in zip(axes,benches):\n    xs,means,sds,cols=[],[],[],[]\n    for i,ag in enumerate(agents):\n        if ag in conformal_results[bm]:\n            xs.append(i); means.append(conformal_results[bm][ag][\"coverage_mean\"])\n            sds.append(conformal_results[bm][ag][\"coverage_std\"]); cols.append(COLOURS[ag])\n    ax.bar(xs,means,yerr=sds,color=cols,alpha=0.85,capsize=4)\n    ax.axhline(target,color=\"black\",ls=\"--\",lw=1.5,label=f\"Target {target:.0%}\")\n    ax.set_xticks(xs); ax.set_xticklabels([LABELS[agents[i]] for i in xs],rotation=20)\n    ax.set_ylim(0,1); ax.set_title(bm.upper(),fontweight=\"bold\"); ax.set_ylabel(\"Empirical Coverage\")\n    ax.legend(fontsize=8)\nfig.suptitle(f\"Conformal Prediction Coverage ({target:.0%} target) — Closer to line = better calibrated\",\n             fontsize=12,fontweight=\"bold\",y=1.02)\nplt.tight_layout()\np=os.path.join(WORK_DIR,\"conformal_coverage.png\")\nplt.savefig(p,dpi=150,bbox_inches=\"tight\",facecolor=\"white\"); plt.show()\nprint(f\"Saved: {p}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"32afe729-2e59-47ba-8186-8c10f494f08a","cell_type":"code","source":"# CELL 15 — Statistical Summary (all benchmarks)\nimport numpy as np\nfrom scipy import stats as scipy_stats\nAGENTS=[\"vanilla\",\"reinforce\",\"ppo_clip\",\"hra\"]\ndef summarise(rlist,metric):\n    vals=[r[metric] for r in rlist if metric in r]\n    if len(vals)<2: return {}\n    lo,hi=ci95(vals)\n    return {\"mean\":np.mean(vals),\"std\":np.std(vals,ddof=1),\"ci_lo\":lo,\"ci_hi\":hi,\"vals\":vals}\nBENCH_METRICS={\"scienceqa\":[\"Task_Success_Rate\",\"Hallucination_Rate\"],\n               \"vqa_v2\":[\"Task_Success_Rate\",\"Hallucination_Rate\"],\n               \"pope\":[\"POPE_Accuracy\",\"POPE_F1\"],\n               \"mmbench\":[\"Task_Success_Rate\"],\"textvqa\":[\"Task_Success_Rate\"]}\nfor bm,metrics in BENCH_METRICS.items():\n    if not results.get(bm) or not any(results[bm].values()): continue\n    print(f\"\\n{'='*64}\\n{bm.upper()}\\n{'='*64}\")\n    for metric in metrics:\n        print(f\"\\n  {metric}\")\n        sums={}\n        for ag in AGENTS:\n            s=summarise(results[bm].get(ag,[]),metric)\n            if not s: continue\n            sums[ag]=s\n            print(f\"  {ag:<12}{s['mean']:>8.4f} +/- {s['std']:.4f}  [{s['ci_lo']:+.4f},{s['ci_hi']:+.4f}]\")\n        if \"reinforce\" in sums and \"hra\" in sums:\n            rv,hv=sums[\"reinforce\"][\"vals\"],sums[\"hra\"][\"vals\"]; mn=min(len(rv),len(hv))\n            if mn>=2:\n                pooled=np.sqrt(((mn-1)*np.std(rv[:mn],ddof=1)**2+(mn-1)*np.std(hv[:mn],ddof=1)**2)/(2*mn-2)+1e-10)\n                d=(np.mean(hv[:mn])-np.mean(rv[:mn]))/pooled; t,p=scipy_stats.ttest_rel(rv[:mn],hv[:mn])\n                print(f\"    HRA vs REINFORCE: d={d:.2f} {'p<.05' if p<0.05 else f'p={p:.3f}'}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"8843c066-49ff-43a9-a420-0ee47b92c208","cell_type":"code","source":"# CELL 16 — Training Curves\nimport matplotlib.pyplot as plt, numpy as np, os\nCOLOURS={\"reinforce\":\"#C0392B\",\"ppo_clip\":\"#E67E22\",\"hra\":\"#1B6B7B\"}\nLABELS={\"reinforce\":\"Std REINFORCE\",\"ppo_clip\":\"PPO-Clip\",\"hra\":\"HRA-RL\"}\nfig,axes=plt.subplots(1,3,figsize=(18,5)); fig.suptitle(\"Training Reward Curves — 8 Seeds\",fontsize=13,fontweight=\"bold\")\nfor ax,(agent,colour) in zip(axes,COLOURS.items()):\n    logs=train_logs.get(agent,[])\n    if not logs: ax.set_title(f\"{LABELS[agent]}\\n(no data)\"); continue\n    allr=[]\n    for df in logs: ax.plot(df[\"step\"],df[\"reward_mean\"],alpha=0.3,lw=0.8,color=colour); allr.append(df[\"reward_mean\"].values)\n    ml=max(len(r) for r in allr); pad=np.array([np.pad(r,(0,ml-len(r)),constant_values=np.nan) for r in allr])\n    mean=np.nanmean(pad,axis=0); sd=np.nanstd(pad,axis=0); steps=np.linspace(CFG[\"LOG_EVERY\"],CFG[\"PPO_STEPS\"],ml)\n    ax.plot(steps,mean,lw=2.5,color=colour,ls=\"--\",zorder=5); ax.fill_between(steps,mean-sd,mean+sd,alpha=0.15,color=colour)\n    ax.set_title(LABELS[agent],fontweight=\"bold\"); ax.set_xlabel(\"Step\"); ax.set_ylabel(\"Mean Reward\")\nplt.tight_layout(); p=os.path.join(WORK_DIR,\"training_curves.png\")\nplt.savefig(p,dpi=150,bbox_inches=\"tight\",facecolor=\"white\"); plt.show(); print(f\"Saved: {p}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"a1eec950-ec43-48cf-8ec3-fc583745badd","cell_type":"code","source":"# CELL 17 — SRIP Gradient Variance\nimport matplotlib.pyplot as plt, matplotlib.gridspec as gridspec, pandas as pd, numpy as np, os\nCOLOURS={\"reinforce\":\"#C0392B\",\"ppo_clip\":\"#E67E22\",\"hra\":\"#1B6B7B\"}\nLABELS={\"reinforce\":\"Std REINFORCE\",\"ppo_clip\":\"PPO-Clip\",\"hra\":\"HRA-RL\"}\nfig=plt.figure(figsize=(18,11)); gs=gridspec.GridSpec(2,3,figure=fig,hspace=0.4,wspace=0.35)\nfor col,(agent,colour) in enumerate(COLOURS.items()):\n    ax=fig.add_subplot(gs[0,col]); dfs=grad_store.get(agent,[])\n    if not dfs: ax.set_title(f\"{LABELS[agent]}\\n(no data)\"); continue\n    for g in dfs: ax.plot(g[\"step\"],g[\"clipped_norm\"],alpha=0.3,lw=0.6,color=colour)\n    c=pd.concat(dfs); mn=c.groupby(\"step\")[\"clipped_norm\"].mean()\n    ax.plot(mn.index,mn.values,lw=2,color=colour,ls=\"--\"); ax.set_title(LABELS[agent],fontweight=\"bold\")\n    ax.set_xlabel(\"Step\"); ax.set_ylabel(\"Grad Norm\")\nax4=fig.add_subplot(gs[1,0])\nfor agent,colour in COLOURS.items():\n    dfs=grad_store.get(agent,[])\n    if not dfs: continue\n    c=pd.concat(dfs); v=c.groupby(\"step\")[\"clipped_norm\"].std(); ax4.plot(v.index,v.values,color=colour,lw=2,label=LABELS[agent])\nax4.set_title(\"SRIP: Grad Norm SD Across Seeds\",fontweight=\"bold\"); ax4.legend(fontsize=7)\nax5=fig.add_subplot(gs[1,1]); bd,bl,bc=[],[],[]\nfor agent,colour in COLOURS.items():\n    dfs=grad_store.get(agent,[])\n    if not dfs: continue\n    bd.append([g[\"clipped_norm\"].std() for g in dfs]); bl.append(LABELS[agent]); bc.append(colour)\nif bd:\n    bp=ax5.boxplot(bd,patch_artist=True,labels=bl)\n    for pt,c in zip(bp[\"boxes\"],bc): pt.set_facecolor(c); pt.set_alpha(0.7)\nax5.set_title(\"Per-Seed Grad Norm SD\",fontweight=\"bold\")\nax6=fig.add_subplot(gs[1,2])\nfor agent,colour in COLOURS.items():\n    dfs=grad_store.get(agent,[]); rl=results[\"scienceqa\"].get(agent,[])\n    if not dfs or not rl: continue\n    tsr=[r.get(\"Task_Success_Rate\",0) for r in rl]; gsd=[g[\"clipped_norm\"].std() for g in dfs]; mn=min(len(tsr),len(gsd))\n    ax6.scatter(gsd[:mn],tsr[:mn],color=colour,s=50,alpha=0.8,label=LABELS[agent])\nax6.set_title(\"Grad Variance vs TSR\",fontweight=\"bold\"); ax6.legend(fontsize=6)\nfig.suptitle(\"Sparse Reward-Induced Policy Instability (SRIP)\",fontsize=13,fontweight=\"bold\",y=0.99)\np=os.path.join(WORK_DIR,\"srip_analysis.png\"); plt.savefig(p,dpi=150,bbox_inches=\"tight\",facecolor=\"white\"); plt.show(); print(f\"Saved: {p}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"0ce6c425-f979-4001-a5b7-4b3b8167b076","cell_type":"code","source":"# CELL 18 — Save All Results\nimport pandas as pd, os, json as _json\nrows=[r for b in results for a in results[b] for r in results[b][a]]\ndf=pd.DataFrame(rows); p=os.path.join(WORK_DIR,\"all_results_FINAL.csv\"); df.to_csv(p,index=False)\nprint(f\"Saved: {p}\\n\")\nfor bm in results:\n    sub=df[df.benchmark==bm]\n    if sub.empty: continue\n    cols=[c for c in [\"Task_Success_Rate\",\"Hallucination_Rate\",\"POPE_Accuracy\",\"POPE_F1\"] if c in sub.columns]\n    print(f\"\\n{bm.upper()}:\"); print(sub.groupby(\"agent\")[cols].mean().round(4).to_string())\nprint(\"\\nFiles to download: all_results_FINAL.csv, conformal_results.json,\")\nprint(\"conformal_coverage.png, training_curves.png, srip_analysis.png\")\n","metadata":{},"outputs":[],"execution_count":null}]}