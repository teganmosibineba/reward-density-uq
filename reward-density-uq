{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12"},"kaggle":{"accelerator":"none","dataSources":[],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":5,"nbformat":4,"cells":[{"id":"f386c4d7-1b83-4ead-8ae2-571f91c59a9d","cell_type":"code","source":"# CELL 1 — Install + T4 patches (run every session)\nimport os, sys, re, shutil, subprocess, warnings\nwarnings.filterwarnings(\"ignore\")\nos.environ[\"BNB_CUDA_VERSION\"] = \"128\"\nos.environ[\"LD_LIBRARY_PATH\"]  = \"/usr/local/cuda/lib64:\" + os.environ.get(\"LD_LIBRARY_PATH\",\"\")\nSYS = \"/usr/local/lib/python3.12/dist-packages\"\ndef run(cmd): subprocess.run(cmd, shell=True, check=False)\n\n# transformers 4.44.2 to system path\n_xfm=f\"{SYS}/transformers\"; _bak=f\"{SYS}/transformers_orig_bak\"; _need=True\nif os.path.exists(f\"{_xfm}/__init__.py\"):\n    with open(f\"{_xfm}/__init__.py\") as f:\n        if \"4.44\" in f.read(): _need=False\nif _need:\n    print(\"Installing transformers 4.44.2...\")\n    if os.path.exists(_xfm) and not os.path.exists(_bak): shutil.move(_xfm,_bak)\n    elif os.path.exists(_xfm): shutil.rmtree(_xfm)\n    run(f\"pip install --quiet --force-reinstall --no-cache-dir --target={SYS} transformers==4.44.2 tokenizers==0.19.1\")\nelse: print(\"transformers 4.44.x in place\")\n\n# utils/__init__.py compat\n_f=f\"{SYS}/transformers/utils/__init__.py\"\nif os.path.exists(_f):\n    with open(_f) as fp: s=fp.read()\n    if \"# compat\" not in s:\n        with open(_f,\"a\") as fp:\n            fp.write(\"\\n# compat\\ntry:\\n    from transformers.utils.import_utils import (is_flax_available,is_tf_available,is_torch_tpu_available)\\n\"\n                     \"except ImportError:\\n    def is_flax_available(): return False\\n    def is_tf_available(): return False\\n    def is_torch_tpu_available(): return False\\n\")\n\n# sentencepiece pb2 duplicate-descriptor patch\n_f=f\"{SYS}/transformers/utils/sentencepiece_model_pb2_new.py\"\nif os.path.exists(_f):\n    with open(_f) as fp: s=fp.read()\n    if \"PATCHED_PROTO\" not in s:\n        s=s.replace(\"DESCRIPTOR = _descriptor_pool.Default().AddSerializedFile(\",\n                    \"try:\\n    DESCRIPTOR = _descriptor_pool.Default().AddSerializedFile(\")\n        s=s.replace(\")\\n\\n_globals\",\n                    \")\\nexcept Exception:\\n    from google.protobuf import descriptor_pool as _dp2\\n\"\n                    \"    DESCRIPTOR = _dp2.Default().FindFileByName('sentencepiece_model.proto')\\n# PATCHED_PROTO\\n\\n_globals\")\n        with open(_f,\"w\") as fp: fp.write(s)\n\n# fake_impl.py op double-registration\n_f=f\"{SYS}/torch/_library/fake_impl.py\"\nif os.path.exists(_f):\n    with open(_f) as fp: s=fp.read()\n    if \"PATCHED_ALLOW_OVERRIDE\" not in s:\n        s=s.replace(\"        if not allow_override:\\n            if self.kernel is not None:\\n                raise RuntimeError(\\n\",\n                    \"        if not allow_override:\\n            if self.kernel is not None:\\n                return self.kernel  # PATCHED_ALLOW_OVERRIDE\\n            if False:\\n                raise RuntimeError(\\n\")\n        with open(_f,\"w\") as fp: fp.write(s)\n\n# clear stale modules\n_preserve=(\"torchvision\",\"sentencepiece\",\"google.protobuf\",\"google._upb\")\n_preserve_c=(\"sentencepiece_model_pb2\",\"pb2_new\",\"_pb2\")\n_del=[k for k in sys.modules if any(k.startswith(p) for p in [\"transformers\",\"bitsandbytes\",\"peft\",\"tokenizers\"])\n      and not any(k.startswith(p) for p in _preserve) and not any(p in k for p in _preserve_c)]\nfor k in _del: del sys.modules[k]\n\nrun(\"pip install --quiet peft>=0.12.0 accelerate>=0.30.0 datasets huggingface_hub scipy scikit-learn pillow sentence-transformers\")\nprint(\"Cell 1 complete.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"4c901e85-3521-46ec-9721-aba73f00a324","cell_type":"code","source":"# CELL 2 — Imports\nimport os, sys, gc, json, warnings, random, math\nimport numpy as np, pandas as pd, torch\nimport torch.nn.functional as F\nimport matplotlib.pyplot as plt\nimport matplotlib.gridspec as gridspec\nfrom PIL import Image\nfrom scipy import stats as scipy_stats\nfrom datasets import load_dataset as _real_load_dataset\nfrom huggingface_hub import snapshot_download\nwarnings.filterwarnings(\"ignore\")\nos.environ[\"BNB_CUDA_VERSION\"]=\"128\"\nfrom transformers import (LlavaForConditionalGeneration, BitsAndBytesConfig,\n                          AutoTokenizer, CLIPImageProcessor, LlavaProcessor, AutoModel)\nfrom peft import get_peft_model, LoraConfig\nimport transformers, peft\nprint(f\"torch {torch.__version__} | CUDA {torch.cuda.is_available()} | {torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU'}\")\nprint(f\"transformers {transformers.__version__} | peft {peft.__version__}\")\ntry:\n    import bitsandbytes as bnb; print(f\"bitsandbytes {bnb.__version__} OK\"); BNB_OK=True\nexcept Exception as e: print(f\"bitsandbytes unavailable: {e}\"); BNB_OK=False\nprint(\"Cell 2 complete.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"3c0fcd00-229a-4974-9a8b-0b21a41ae0df","cell_type":"code","source":"# CELL 3 — Configuration\nCFG = {\n    \"MODEL_ID\":\"llava-hf/llava-1.5-7b-hf\",\n    \"LORA_RANK\":16,\"PPO_STEPS\":400,\"TRAIN_ITEMS\":400,\n    \"LEARNING_RATE\":1e-5,\"TEMPERATURE\":0.9,\"MAX_NEW_TOKENS\":50,\n    \"EMA_DECAY\":0.9,\"GRAD_CLIP\":0.5,\"PPO_EPSILON\":0.2,\n    \"TEST_ITEMS\":500,\"POPE_ITEMS\":500,\"MMB_ITEMS\":400,\"TEXTVQA_ITEMS\":400,\n    \"EVAL_TEMPERATURE\":0.7,\n    \"SEEDS\":[42,123,7,1,2,3,4,5],\n    \"W_TASK\":1.0,\"W_FACT\":0.5,\"PENALTY\":-0.5,\n    \"FGM_THRESHOLD\":0.6,\"TASK_THRESHOLD\":0.7,\"CI_LEVEL\":0.95,\n    \"CONFORMAL_ALPHA\":0.1,  # target 90% coverage\n    \"LOG_EVERY\":50,\n}\nprint(\"CFG ready. 5 benchmarks, 8 seeds, conformal alpha=0.1 (90% target coverage)\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"2543871f-9df4-4ea6-88d1-54a2092725d9","cell_type":"code","source":"# CELL 4 — Environment\nimport os, gc, random\nimport numpy as np, torch\nWORK_DIR=\"/kaggle/working\" if os.path.exists(\"/kaggle/working\") else \"/content\"\nCACHE_DIR=os.path.join(WORK_DIR,\"llava_cache\"); os.makedirs(CACHE_DIR,exist_ok=True)\n\ndef set_seed(seed):\n    random.seed(seed); np.random.seed(seed); torch.manual_seed(seed)\n    if torch.cuda.is_available(): torch.cuda.manual_seed_all(seed)\n\ndef nuke():\n    for _n in [\"m\",\"base\",\"model\",\"vm\",\"vanilla_model\",\"lora_model\"]:\n        if _n in globals():\n            try: globals()[_n].cpu()\n            except: pass\n            try: del globals()[_n]\n            except: pass\n    gc.collect(); torch.cuda.empty_cache(); torch.cuda.synchronize()\n    free,total=torch.cuda.mem_get_info(); print(f\"  VRAM: {free/1024**3:.1f}/{total/1024**3:.1f} GB\")\n\nREWARD_CONFIGS={\"A: Task Only\":{\"w_task\":1.0,\"w_fact\":0.0,\"penalty\":0.0},\n                \"B: Fact Only\":{\"w_task\":0.0,\"w_fact\":1.0,\"penalty\":-0.5},\n                \"C: No Penalty\":{\"w_task\":1.0,\"w_fact\":0.5,\"penalty\":0.0},\n                \"D: Full HRA\":{\"w_task\":1.0,\"w_fact\":0.5,\"penalty\":-0.5},\n                \"E: Std REINFORCE\":{\"w_task\":1.0,\"w_fact\":0.0,\"penalty\":0.0}}\n\ndef compute_reward(config_name,fact_score):\n    cfg=REWARD_CONFIGS.get(config_name,REWARD_CONFIGS[\"D: Full HRA\"])\n    r_task=1.0 if fact_score>CFG[\"TASK_THRESHOLD\"] else 0.0\n    r_fact=fact_score if fact_score>=CFG[\"FGM_THRESHOLD\"] else cfg[\"penalty\"]\n    return cfg[\"w_task\"]*r_task+cfg[\"w_fact\"]*r_fact\n\nalready_cached=any(f.endswith(\".safetensors\") for _,_,files in os.walk(CACHE_DIR) for f in files)\nif not already_cached:\n    print(\"Downloading model (one-time ~14GB)...\")\n    snapshot_download(repo_id=CFG[\"MODEL_ID\"],cache_dir=CACHE_DIR,\n        ignore_patterns=[\"*.msgpack\",\"*.h5\",\"flax_model*\",\"tf_model*\"])\n    already_cached=True; print(\"Done.\")\nelse: print(f\"Model cached: {CACHE_DIR}\")\nfree,total=torch.cuda.mem_get_info(); print(f\"VRAM: {free/1024**3:.1f}/{total/1024**3:.1f} GB\")\nprint(\"Cell 4 complete.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"95912103-fea3-4486-b425-ac8943543626","cell_type":"code","source":"# CELL 5 — Model Factory\nimport gc, torch\nfrom transformers import LlavaForConditionalGeneration, BitsAndBytesConfig\nfrom peft import get_peft_model, LoraConfig\ndef _bnb():\n    if not BNB_OK: return None\n    return BitsAndBytesConfig(load_in_4bit=True,bnb_4bit_compute_dtype=torch.float16,\n        bnb_4bit_use_double_quant=False,bnb_4bit_quant_type=\"nf4\")\ndef _lora():\n    return LoraConfig(r=CFG[\"LORA_RANK\"],lora_alpha=CFG[\"LORA_RANK\"]*2,lora_dropout=0.05,\n        bias=\"none\",target_modules=[\"q_proj\",\"v_proj\"],task_type=\"CAUSAL_LM\")\ndef make_lora_model():\n    gc.collect(); torch.cuda.empty_cache()\n    bnb=_bnb(); kw=dict(device_map=\"auto\",cache_dir=CACHE_DIR,local_files_only=already_cached)\n    if bnb: kw[\"quantization_config\"]=bnb; print(\"  Mode: 4-bit\")\n    else: kw[\"torch_dtype\"]=torch.float16; print(\"  Mode: float16\")\n    base=LlavaForConditionalGeneration.from_pretrained(CFG[\"MODEL_ID\"],**kw)\n    model=get_peft_model(base,_lora())\n    try: model.enable_input_require_grads(); model.gradient_checkpointing_enable()\n    except: pass\n    model.print_trainable_parameters()\n    free,_=torch.cuda.mem_get_info(); print(f\"  VRAM free: {free/1024**3:.1f} GB\")\n    return model\ndef make_vanilla_model():\n    gc.collect(); torch.cuda.empty_cache()\n    bnb=_bnb(); kw=dict(device_map=\"auto\",cache_dir=CACHE_DIR,local_files_only=already_cached)\n    if bnb: kw[\"quantization_config\"]=bnb\n    else: kw[\"torch_dtype\"]=torch.float16\n    return LlavaForConditionalGeneration.from_pretrained(CFG[\"MODEL_ID\"],**kw)\nprint(f\"Model factory ready. 4-bit={'YES' if BNB_OK else 'NO'}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"15ecc0d0-23c0-484d-9b86-c88643cb292c","cell_type":"code","source":"# CELL 6 — Processor + FGM\nimport torch, torch.nn.functional as F\nfrom transformers import CLIPImageProcessor, AutoTokenizer, LlavaProcessor, AutoModel\n_img=CLIPImageProcessor.from_pretrained(CFG[\"MODEL_ID\"],cache_dir=CACHE_DIR,local_files_only=already_cached)\n_tok=AutoTokenizer.from_pretrained(CFG[\"MODEL_ID\"],cache_dir=CACHE_DIR,local_files_only=already_cached,use_fast=False)\nprocessor=LlavaProcessor(image_processor=_img,tokenizer=_tok)\nprocessor.tokenizer.pad_token=processor.tokenizer.eos_token\nprocessor.tokenizer.padding_side=\"left\"\nprint(\"Processor ready\")\n_fgm_tok=AutoTokenizer.from_pretrained(\"sentence-transformers/all-MiniLM-L6-v2\",use_fast=False)\n_fgm_mod=AutoModel.from_pretrained(\"sentence-transformers/all-MiniLM-L6-v2\").eval()\ndef fgm_score(r,g):\n    enc=_fgm_tok([r,g],padding=True,truncation=True,max_length=128,return_tensors=\"pt\")\n    with torch.no_grad(): out=_fgm_mod(**enc)\n    mask=enc[\"attention_mask\"].unsqueeze(-1).float()\n    emb=(out.last_hidden_state*mask).sum(1)/mask.sum(1).clamp(min=1e-9)\n    emb=F.normalize(emb,p=2,dim=1)\n    return float(F.cosine_similarity(emb[0:1],emb[1:2]).item())\nprint(f\"FGM ready (cat/cat={fgm_score('cat','cat'):.3f})\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"c83571ba-4168-4229-b33a-b330449cf971","cell_type":"code","source":"# CELL 7 — Reward Configs\nfor name,cfg in REWARD_CONFIGS.items(): print(f\"  {name}: {cfg}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"8270a22e-350c-4484-a158-6d65c9ff461c","cell_type":"code","source":"# CELL 8 — Datasets: ScienceQA, VQA-v2, POPE, MMBench, TextVQA\nimport random\nfrom PIL import Image\n\n_sciqa_cache={}\ndef _get_sciqa(split):\n    if split not in _sciqa_cache:\n        _sciqa_cache[split]=_real_load_dataset(\"derek-thomas/ScienceQA\",split=split)\n    return _sciqa_cache[split]\ndef build_scienceqa(split=\"train\",max_items=400,seed=42):\n    ds=_get_sciqa(split); idx=[i for i,r in enumerate(ds) if r.get(\"image\") is not None]\n    random.seed(seed); random.shuffle(idx); items=[]\n    for i in idx[:max_items*3]:\n        if len(items)>=max_items: break\n        try:\n            row=ds[i]; img=row[\"image\"]\n            if not isinstance(img,Image.Image): continue\n            if img.mode!=\"RGB\": img=img.convert(\"RGB\")\n            ch=row.get(\"choices\",[]); ans=row.get(\"answer\",0)\n            gt=ch[ans] if ch and isinstance(ans,int) and ans<len(ch) else str(ans)\n            q=row.get(\"question\",\"\")\n            if ch: q+=\" Choices: \"+\", \".join(ch)\n            items.append({\"prompt\":q,\"ground_truth\":gt,\"image\":img,\"source\":\"scienceqa\"})\n        except: continue\n    print(f\"  ScienceQA {split}: {len(items)} (seed={seed})\")\n    return items\n\ndef build_vqa(max_items=500,skip=0,seed=42):\n    stream=_real_load_dataset(\"lmms-lab/VQAv2\",split=\"validation\",streaming=True)\n    items,skipped=[],0\n    for row in stream:\n        if skipped<skip: skipped+=1; continue\n        if len(items)>=max_items: break\n        try:\n            raw=row.get(\"answers\",[])\n            if not raw: continue\n            ans=[a[\"answer\"] for a in raw] if isinstance(raw[0],dict) else list(raw)\n            gt=max(set(ans),key=ans.count); img=row.get(\"image\") or row.get(\"img\")\n            if img is None or not isinstance(img,Image.Image): continue\n            if img.mode!=\"RGB\": img=img.convert(\"RGB\")\n            items.append({\"prompt\":row.get(\"question\",\"\"),\"ground_truth\":gt,\"image\":img,\"source\":\"vqa_v2\"})\n        except: continue\n    print(f\"  VQA-v2: {len(items)} (skip={skip})\")\n    return items\n\ndef build_pope(max_items=500,seed=42):\n    try: stream=_real_load_dataset(\"lmms-lab/POPE\",split=\"test\",streaming=True)\n    except Exception: stream=_real_load_dataset(\"lmms-lab/POPE\",split=\"adversarial\",streaming=True)\n    items=[]\n    for row in stream:\n        if len(items)>=max_items: break\n        try:\n            img=row.get(\"image\")\n            if img is None or not isinstance(img,Image.Image): continue\n            if img.mode!=\"RGB\": img=img.convert(\"RGB\")\n            items.append({\"prompt\":row.get(\"question\",\"\"),\n                          \"ground_truth\":str(row.get(\"answer\",\"\")).strip().lower(),\n                          \"image\":img,\"source\":\"pope\"})\n        except: continue\n    print(f\"  POPE: {len(items)}\")\n    return items\n\ndef build_mmbench(max_items=400,seed=42):\n    try: stream=_real_load_dataset(\"lmms-lab/MMBench\",split=\"dev\",streaming=True)\n    except Exception:\n        try: stream=_real_load_dataset(\"HuggingFaceM4/MMBench_dev\",split=\"train\",streaming=True)\n        except Exception:\n            print(\"  MMBench: unavailable, skipping\"); return []\n    items=[]\n    for row in stream:\n        if len(items)>=max_items: break\n        try:\n            img=row.get(\"image\")\n            if img is None or not isinstance(img,Image.Image): continue\n            if img.mode!=\"RGB\": img=img.convert(\"RGB\")\n            q=row.get(\"question\",\"\")\n            opts=[]\n            for k in [\"A\",\"B\",\"C\",\"D\"]:\n                v=row.get(k)\n                if v: opts.append(f\"{k}. {v}\")\n            if opts: q+=\" Options: \"+\" \".join(opts)\n            ans=row.get(\"answer\",\"\")\n            gt=str(ans)\n            items.append({\"prompt\":q,\"ground_truth\":gt,\"image\":img,\"source\":\"mmbench\"})\n        except: continue\n    print(f\"  MMBench: {len(items)}\")\n    return items\n\ndef build_textvqa(max_items=400,seed=42):\n    try: stream=_real_load_dataset(\"lmms-lab/textvqa\",split=\"validation\",streaming=True)\n    except Exception:\n        try: stream=_real_load_dataset(\"textvqa\",split=\"validation\",streaming=True)\n        except Exception:\n            print(\"  TextVQA: unavailable, skipping\"); return []\n    items=[]\n    for row in stream:\n        if len(items)>=max_items: break\n        try:\n            img=row.get(\"image\")\n            if img is None or not isinstance(img,Image.Image): continue\n            if img.mode!=\"RGB\": img=img.convert(\"RGB\")\n            ans=row.get(\"answers\",[]) or [row.get(\"answer\",\"\")]\n            if isinstance(ans,list) and ans:\n                gt=max(set(ans),key=ans.count) if len(ans)>1 else str(ans[0])\n            else: gt=str(ans)\n            items.append({\"prompt\":row.get(\"question\",\"\"),\"ground_truth\":gt,\"image\":img,\"source\":\"textvqa\"})\n        except: continue\n    print(f\"  TextVQA: {len(items)}\")\n    return items\n\nprint(\"Building 5 eval sets (a few minutes)...\")\nSCIQA_TEST=build_scienceqa(\"test\",CFG[\"TEST_ITEMS\"],seed=42)\nVQA_TEST=build_vqa(CFG[\"TEST_ITEMS\"],skip=0,seed=42)\nPOPE_TEST=build_pope(CFG[\"POPE_ITEMS\"],seed=42)\nMMB_TEST=build_mmbench(CFG[\"MMB_ITEMS\"],seed=42)\nTEXTVQA_TEST=build_textvqa(CFG[\"TEXTVQA_ITEMS\"],seed=42)\nprint(f\"Done. SciQA={len(SCIQA_TEST)} VQA={len(VQA_TEST)} POPE={len(POPE_TEST)} MMB={len(MMB_TEST)} TextVQA={len(TEXTVQA_TEST)}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"f7cc8028-2d44-425d-aae8-b329102cdb6a","cell_type":"code","source":"# CELL 9 — Metrics + conformal nonconformity scores\nimport numpy as np\nfrom scipy import stats as scipy_stats\n\ndef compute_metrics(responses, ground_truths, source=\"generic\"):\n    if source==\"pope\":\n        tp=fp=tn=fn=0\n        for resp,gt in zip(responses,ground_truths):\n            pred=\"yes\" if \"yes\" in resp.lower()[:20] else \"no\"\n            if gt==\"yes\" and pred==\"yes\": tp+=1\n            elif gt==\"no\" and pred==\"yes\": fp+=1\n            elif gt==\"no\" and pred==\"no\": tn+=1\n            elif gt==\"yes\" and pred==\"no\": fn+=1\n        acc=(tp+tn)/max(1,tp+fp+tn+fn); prec=tp/max(1,tp+fp); rec=tp/max(1,tp+fn)\n        f1=2*prec*rec/max(1e-9,prec+rec)\n        return {\"POPE_Accuracy\":round(acc,4),\"POPE_F1\":round(f1,4),\n                \"Hallucination_Rate\":round(fp/max(1,fp+tn),4),\"n\":len(responses)}\n    scores,hits,em=[],[],[]\n    for resp,gt in zip(responses,ground_truths):\n        s=fgm_score(resp,gt); scores.append(s)\n        hits.append(1 if s>=CFG[\"FGM_THRESHOLD\"] else 0)\n        em.append(1 if gt.lower().strip() in resp.lower() else 0)\n    return {\"Task_Success_Rate\":round(np.mean(hits),4),\n            \"Semantic_Consistency_Score\":round(np.mean(scores),4),\n            \"Hallucination_Rate\":round(1-np.mean(hits),4),\n            \"Exact_Match_Accuracy\":round(np.mean(em),4),\n            \"Mean_FGM_Score\":round(np.mean(scores),4),\"n\":len(responses)}\n\ndef get_fgm_scores(responses, ground_truths):\n    # Returns raw FGM scores for conformal prediction (nonconformity = 1 - fgm)\n    return [fgm_score(r,g) for r,g in zip(responses,ground_truths)]\n\ndef ci95(values):\n    n=len(values)\n    if n<2: return (float(values[0]) if n==1 else 0,0)\n    m,se=np.mean(values),scipy_stats.sem(values)\n    t=scipy_stats.t.ppf(0.975,df=n-1)\n    return round(m-t*se,4),round(m+t*se,4)\nprint(\"Metrics + conformal scoring ready.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"5f3b1b08-f39a-4c92-a231-7cef20d89dc2","cell_type":"code","source":"# CELL 10 — Training Loop\nimport torch, numpy as np, pandas as pd\ndef run_training(model,config_name,questions,seed=42,n_steps=None,use_ppo_clip=False):\n    if n_steps is None: n_steps=CFG[\"PPO_STEPS\"]\n    set_seed(seed)\n    opt=torch.optim.AdamW([p for p in model.parameters() if p.requires_grad],lr=CFG[\"LEARNING_RATE\"],weight_decay=0.01)\n    baseline=0.0; eps=CFG[\"PPO_EPSILON\"]; algo=\"PPO-Clip\" if use_ppo_clip else \"REINFORCE\"\n    reward_log,grad_log=[],[]; wr,wf,wt=[],[],[]\n    print(f\"\\n{'='*58}\\n[{config_name}] [{algo}] seed={seed} steps={n_steps}\\n{'='*58}\")\n    for step in range(n_steps):\n        q=questions[step%len(questions)]\n        prompt=f\"USER: <image>\\n{q['prompt']}\\nASSISTANT:\"\n        inputs=processor(text=prompt,images=q[\"image\"],return_tensors=\"pt\").to(\"cuda\")\n        with torch.no_grad():\n            gen=model.generate(**inputs,max_new_tokens=CFG[\"MAX_NEW_TOKENS\"],do_sample=True,\n                temperature=CFG[\"TEMPERATURE\"],pad_token_id=processor.tokenizer.eos_token_id)\n        new=gen[0][inputs.input_ids.shape[1]:]; resp=processor.decode(new,skip_special_tokens=True)\n        fs=fgm_score(resp,q[\"ground_truth\"]); reward=compute_reward(config_name,fs)\n        adv=reward-baseline; baseline=CFG[\"EMA_DECAY\"]*baseline+(1-CFG[\"EMA_DECAY\"])*reward\n        seq=torch.cat([inputs.input_ids,new.unsqueeze(0)],dim=1)\n        lab=seq.clone(); lab[:,:inputs.input_ids.shape[1]]=-100\n        out=model(input_ids=seq,attention_mask=torch.ones_like(seq),labels=lab); lp=-out.loss\n        advt=torch.tensor(adv,dtype=torch.float32,device=lp.device)\n        if use_ppo_clip:\n            with torch.no_grad():\n                old=model(input_ids=seq,attention_mask=torch.ones_like(seq),labels=lab); olp=-old.loss.detach()\n            ratio=torch.exp(lp-olp); clip=torch.clamp(ratio,1-eps,1+eps); loss=-torch.min(ratio*advt,clip*advt)\n        else: loss=-lp*advt\n        opt.zero_grad(); loss.backward()\n        rg=sum(p.grad.data.norm(2).item()**2 for p in model.parameters() if p.grad is not None)**0.5\n        cg=torch.nn.utils.clip_grad_norm_(model.parameters(),CFG[\"GRAD_CLIP\"]).item(); opt.step()\n        wr.append(reward); wf.append(fs); wt.append(float(fs>CFG[\"TASK_THRESHOLD\"]))\n        grad_log.append({\"step\":step+1,\"raw_grad_norm\":rg,\"clipped_norm\":cg,\"reward\":reward,\"advantage\":adv,\"fgm\":fs})\n        if (step+1)%CFG[\"LOG_EVERY\"]==0:\n            k=CFG[\"LOG_EVERY\"]; rm=np.mean(wr[-k:]); fm=np.mean(wf[-k:]); tsr=np.mean(wt[-k:])\n            gn=np.mean([g[\"clipped_norm\"] for g in grad_log[-k:]])\n            print(f\"  Step {step+1:4d}/{n_steps} | R={rm:+.3f} | FGM={fm:.3f} | TSR={tsr:.3f} | Grad={gn:.3f}\")\n            reward_log.append({\"step\":step+1,\"reward_mean\":rm,\"fgm_mean\":fm,\"tsr\":tsr,\"grad_norm\":gn,\n                               \"config\":config_name,\"seed\":seed,\"algo\":algo})\n    print(f\"  Done. Mean R={np.mean(wr):.4f}\")\n    s_df=pd.DataFrame(reward_log); g_df=pd.DataFrame(grad_log)\n    g_df[\"config\"]=config_name; g_df[\"seed\"]=seed; g_df[\"algo\"]=algo\n    return s_df,g_df\nprint(\"run_training ready.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"6fbc508d-a55e-4849-85dc-19163fb67b70","cell_type":"code","source":"# CELL 11 — Evaluation Loop (stores responses for conformal prediction)\nimport torch\ndef run_evaluation(label,model,questions,seed=42,log_interval=200):\n    set_seed(seed); responses,gts=[],[]\n    print(f\"Eval [{label}] n={len(questions)}\")\n    for i,q in enumerate(questions):\n        prompt=f\"USER: <image>\\n{q['prompt']}\\nASSISTANT:\"\n        inputs=processor(text=prompt,images=q[\"image\"],return_tensors=\"pt\").to(\"cuda\")\n        with torch.no_grad():\n            gen=model.generate(**inputs,max_new_tokens=CFG[\"MAX_NEW_TOKENS\"],do_sample=True,\n                temperature=CFG[\"EVAL_TEMPERATURE\"],pad_token_id=processor.tokenizer.eos_token_id)\n        new=gen[0][inputs.input_ids.shape[1]:]; resp=processor.decode(new,skip_special_tokens=True)\n        responses.append(resp); gts.append(q[\"ground_truth\"])\n        if (i+1)%log_interval==0: print(f\"  {i+1}/{len(questions)}\")\n    return responses,gts\nprint(\"run_evaluation ready.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"cadb0fd3-bfcf-47c0-b693-dbe8e5c695c1","cell_type":"code","source":"# CELL 12 — Multi-Seed Experiment (5 benchmarks, stores responses)\nimport os, gc, json as _json, pickle\nBENCHES=[\"scienceqa\",\"vqa_v2\",\"pope\",\"mmbench\",\"textvqa\"]\nTESTSETS={\"scienceqa\":SCIQA_TEST,\"vqa_v2\":VQA_TEST,\"pope\":POPE_TEST,\"mmbench\":MMB_TEST,\"textvqa\":TEXTVQA_TEST}\nSOURCES={\"scienceqa\":\"generic\",\"vqa_v2\":\"generic\",\"pope\":\"pope\",\"mmbench\":\"generic\",\"textvqa\":\"generic\"}\n\nresults={b:{\"reinforce\":[],\"ppo_clip\":[],\"hra\":[],\"vanilla\":[]} for b in BENCHES}\ngrad_store={\"reinforce\":[],\"ppo_clip\":[],\"hra\":[]}\ntrain_logs={\"reinforce\":[],\"ppo_clip\":[],\"hra\":[]}\n# Store raw FGM scores per (benchmark, agent, seed) for conformal prediction\nconformal_scores={b:{\"reinforce\":{},\"ppo_clip\":{},\"hra\":{},\"vanilla\":{}} for b in BENCHES}\ncompleted=[]\n\ntry:\n    cks=sorted([f for f in os.listdir(WORK_DIR) if f.startswith(\"ckpt_seed\") and f.endswith(\".json\")],\n               key=lambda x: os.path.getmtime(os.path.join(WORK_DIR,x)))\n    if cks:\n        with open(os.path.join(WORK_DIR,cks[-1])) as f: completed=_json.load(f).get(\"completed\",[])\n        print(f\"Resuming. Completed: {completed}\")\nexcept Exception as e: print(f\"No checkpoint: {e}\")\nto_run=[s for s in CFG[\"SEEDS\"] if s not in completed]\nprint(f\"Seeds to run: {to_run}\")\n\nfor seed in to_run:\n    print(f\"\\n{'-'*50}\\n  SEED {seed}\\n{'-'*50}\")\n    TRAIN_SQ=build_scienceqa(\"train\",CFG[\"TRAIN_ITEMS\"],seed)\n    for agent,cfg_name,clip in [(\"reinforce\",\"E: Std REINFORCE\",False),\n                                 (\"ppo_clip\",\"E: Std REINFORCE\",True),\n                                 (\"hra\",\"D: Full HRA\",False)]:\n        nuke(); algo=\"PPO-Clip\" if clip else \"REINFORCE\"\n        print(f\"\\n  [{algo}] seed={seed}\")\n        m=make_lora_model()\n        s_df,g_df=run_training(m,cfg_name,TRAIN_SQ,seed=seed,use_ppo_clip=clip)\n        g_df[\"agent\"]=agent; grad_store[agent].append(g_df); train_logs[agent].append(s_df)\n        for bm in BENCHES:\n            ts=TESTSETS[bm]\n            if not ts: continue\n            r,gt=run_evaluation(f\"{agent}-{bm}\",m,ts,seed=42)\n            met=compute_metrics(r,gt,source=SOURCES[bm])\n            met.update({\"seed\":seed,\"agent\":agent,\"benchmark\":bm,\"algo\":algo})\n            results[bm][agent].append(met)\n            if SOURCES[bm]==\"generic\":\n                conformal_scores[bm][agent][seed]=get_fgm_scores(r,gt)\n        nuke()\n    nuke(); print(f\"\\n  [Vanilla] seed={seed}\")\n    vm=make_vanilla_model()\n    for bm in BENCHES:\n        ts=TESTSETS[bm]\n        if not ts: continue\n        r,gt=run_evaluation(f\"Vanilla-{bm}\",vm,ts,seed=42)\n        met=compute_metrics(r,gt,source=SOURCES[bm])\n        met.update({\"seed\":seed,\"agent\":\"vanilla\",\"benchmark\":bm,\"algo\":\"none\"})\n        results[bm][\"vanilla\"].append(met)\n        if SOURCES[bm]==\"generic\":\n            conformal_scores[bm][\"vanilla\"][seed]=get_fgm_scores(r,gt)\n    nuke()\n    completed.append(seed)\n    with open(os.path.join(WORK_DIR,f\"ckpt_seed{seed}.json\"),\"w\") as f:\n        _json.dump({\"completed\":completed},f)\n    with open(os.path.join(WORK_DIR,\"conformal_scores.pkl\"),\"wb\") as f:\n        pickle.dump(conformal_scores,f)\n    rows=[r for b in results for a in results[b] for r in results[b][a]]\n    pd.DataFrame(rows).to_csv(os.path.join(WORK_DIR,\"all_results_live.csv\"),index=False)\n    print(f\"  Checkpoint + conformal scores + CSV saved.\")\n    del TRAIN_SQ; gc.collect()\nprint(\"\\nAll seeds complete.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"55704735-5749-45d4-9f98-055681115fe8","cell_type":"code","source":"# CELL 13 — Split Conformal Prediction (core UQ contribution)\n# Tests whether each agent's behaviour supports valid coverage guarantees.\n# Nonconformity score s = 1 - FGM (low FGM = high nonconformity = likely wrong).\n# Calibrate threshold q_hat on calibration split, test coverage on held-out split.\nimport numpy as np\n\nALPHA=CFG[\"CONFORMAL_ALPHA\"]  # 0.1 -> target 90% coverage\ndef split_conformal(scores, alpha=0.1, cal_frac=0.5, seed=0):\n    s=np.array([1.0-x for x in scores])  # nonconformity\n    n=len(s)\n    if n<10: return None\n    rng=np.random.default_rng(seed); idx=rng.permutation(n)\n    n_cal=int(n*cal_frac)\n    cal,test=s[idx[:n_cal]],s[idx[n_cal:]]\n    # conformal quantile\n    q_level=np.ceil((n_cal+1)*(1-alpha))/n_cal\n    q_level=min(q_level,1.0)\n    q_hat=np.quantile(cal,q_level,method=\"higher\")\n    # coverage on test: fraction with nonconformity <= q_hat (i.e., prediction set contains truth)\n    coverage=float(np.mean(test<=q_hat))\n    avg_set_size=float(np.mean(s<=q_hat))  # proxy for set size / efficiency\n    return {\"q_hat\":round(q_hat,4),\"coverage\":round(coverage,4),\n            \"target\":round(1-alpha,4),\"gap\":round(coverage-(1-alpha),4),\n            \"avg_set_size\":round(avg_set_size,4),\"n\":n}\n\nprint(f\"Conformal prediction (target coverage = {1-ALPHA:.0%})\\n\")\nconformal_results={}\nfor bm in [\"scienceqa\",\"vqa_v2\",\"mmbench\",\"textvqa\"]:\n    if bm not in conformal_scores: continue\n    print(f\"\\n{'='*64}\\n{bm.upper()}\\n{'='*64}\")\n    print(f\"  {'Agent':<12}{'Coverage':>10}{'Target':>9}{'Gap':>9}{'SetSize':>9}\")\n    conformal_results[bm]={}\n    for agent in [\"vanilla\",\"reinforce\",\"ppo_clip\",\"hra\"]:\n        seed_scores=conformal_scores[bm].get(agent,{})\n        if not seed_scores: continue\n        # Pool coverage across seeds (each seed = one conformal run)\n        covs,gaps,sizes=[],[],[]\n        for sd,sc in seed_scores.items():\n            res=split_conformal(sc,alpha=ALPHA,seed=sd)\n            if res: covs.append(res[\"coverage\"]); gaps.append(res[\"gap\"]); sizes.append(res[\"avg_set_size\"])\n        if not covs: continue\n        mc,mg,ms=np.mean(covs),np.mean(gaps),np.mean(sizes)\n        conformal_results[bm][agent]={\"coverage_mean\":round(mc,4),\"coverage_std\":round(np.std(covs,ddof=1) if len(covs)>1 else 0,4),\n                                       \"gap_mean\":round(mg,4),\"set_size_mean\":round(ms,4),\"n_seeds\":len(covs)}\n        flag=\"OK\" if abs(mg)<0.05 else \"MISCALIBRATED\"\n        print(f\"  {agent:<12}{mc:>10.4f}{1-ALPHA:>9.2f}{mg:>+9.4f}{ms:>9.4f}  {flag}\")\n\nimport json as _json, os\nwith open(os.path.join(WORK_DIR,\"conformal_results.json\"),\"w\") as f:\n    _json.dump(conformal_results,f,indent=2)\nprint(\"\\nSaved conformal_results.json\")\nprint(\"\\nKEY INSIGHT: An agent is UQ-compatible if coverage approx target with low cross-seed variance.\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"cc5ae6cc-d330-4de4-b036-e4bdb3827714","cell_type":"code","source":"# CELL 14 — Conformal Coverage Visualisation\nimport matplotlib.pyplot as plt, numpy as np, os\nbenches=[b for b in [\"scienceqa\",\"vqa_v2\",\"mmbench\",\"textvqa\"] if b in conformal_results and conformal_results[b]]\nagents=[\"vanilla\",\"reinforce\",\"ppo_clip\",\"hra\"]\nLABELS={\"vanilla\":\"Vanilla\",\"reinforce\":\"REINFORCE\",\"ppo_clip\":\"PPO-Clip\",\"hra\":\"HRA-RL\"}\nCOLOURS={\"vanilla\":\"#7F8C8D\",\"reinforce\":\"#C0392B\",\"ppo_clip\":\"#E67E22\",\"hra\":\"#1B6B7B\"}\nfig,axes=plt.subplots(1,len(benches),figsize=(5*len(benches),5),squeeze=False); axes=axes[0]\ntarget=1-CFG[\"CONFORMAL_ALPHA\"]\nfor ax,bm in zip(axes,benches):\n    xs,means,sds,cols=[],[],[],[]\n    for i,ag in enumerate(agents):\n        if ag in conformal_results[bm]:\n            xs.append(i); means.append(conformal_results[bm][ag][\"coverage_mean\"])\n            sds.append(conformal_results[bm][ag][\"coverage_std\"]); cols.append(COLOURS[ag])\n    ax.bar(xs,means,yerr=sds,color=cols,alpha=0.85,capsize=4)\n    ax.axhline(target,color=\"black\",ls=\"--\",lw=1.5,label=f\"Target {target:.0%}\")\n    ax.set_xticks(xs); ax.set_xticklabels([LABELS[agents[i]] for i in xs],rotation=20)\n    ax.set_ylim(0,1); ax.set_title(bm.upper(),fontweight=\"bold\"); ax.set_ylabel(\"Empirical Coverage\")\n    ax.legend(fontsize=8)\nfig.suptitle(f\"Conformal Prediction Coverage ({target:.0%} target) — Closer to line = better calibrated\",\n             fontsize=12,fontweight=\"bold\",y=1.02)\nplt.tight_layout()\np=os.path.join(WORK_DIR,\"conformal_coverage.png\")\nplt.savefig(p,dpi=150,bbox_inches=\"tight\",facecolor=\"white\"); plt.show()\nprint(f\"Saved: {p}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"32afe729-2e59-47ba-8186-8c10f494f08a","cell_type":"code","source":"# CELL 15 — Statistical Summary (all benchmarks)\nimport numpy as np\nfrom scipy import stats as scipy_stats\nAGENTS=[\"vanilla\",\"reinforce\",\"ppo_clip\",\"hra\"]\ndef summarise(rlist,metric):\n    vals=[r[metric] for r in rlist if metric in r]\n    if len(vals)<2: return {}\n    lo,hi=ci95(vals)\n    return {\"mean\":np.mean(vals),\"std\":np.std(vals,ddof=1),\"ci_lo\":lo,\"ci_hi\":hi,\"vals\":vals}\nBENCH_METRICS={\"scienceqa\":[\"Task_Success_Rate\",\"Hallucination_Rate\"],\n               \"vqa_v2\":[\"Task_Success_Rate\",\"Hallucination_Rate\"],\n               \"pope\":[\"POPE_Accuracy\",\"POPE_F1\"],\n               \"mmbench\":[\"Task_Success_Rate\"],\"textvqa\":[\"Task_Success_Rate\"]}\nfor bm,metrics in BENCH_METRICS.items():\n    if not results.get(bm) or not any(results[bm].values()): continue\n    print(f\"\\n{'='*64}\\n{bm.upper()}\\n{'='*64}\")\n    for metric in metrics:\n        print(f\"\\n  {metric}\")\n        sums={}\n        for ag in AGENTS:\n            s=summarise(results[bm].get(ag,[]),metric)\n            if not s: continue\n            sums[ag]=s\n            print(f\"  {ag:<12}{s['mean']:>8.4f} +/- {s['std']:.4f}  [{s['ci_lo']:+.4f},{s['ci_hi']:+.4f}]\")\n        if \"reinforce\" in sums and \"hra\" in sums:\n            rv,hv=sums[\"reinforce\"][\"vals\"],sums[\"hra\"][\"vals\"]; mn=min(len(rv),len(hv))\n            if mn>=2:\n                pooled=np.sqrt(((mn-1)*np.std(rv[:mn],ddof=1)**2+(mn-1)*np.std(hv[:mn],ddof=1)**2)/(2*mn-2)+1e-10)\n                d=(np.mean(hv[:mn])-np.mean(rv[:mn]))/pooled; t,p=scipy_stats.ttest_rel(rv[:mn],hv[:mn])\n                print(f\"    HRA vs REINFORCE: d={d:.2f} {'p<.05' if p<0.05 else f'p={p:.3f}'}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"8843c066-49ff-43a9-a420-0ee47b92c208","cell_type":"code","source":"# CELL 16 — Training Curves\nimport matplotlib.pyplot as plt, numpy as np, os\nCOLOURS={\"reinforce\":\"#C0392B\",\"ppo_clip\":\"#E67E22\",\"hra\":\"#1B6B7B\"}\nLABELS={\"reinforce\":\"Std REINFORCE\",\"ppo_clip\":\"PPO-Clip\",\"hra\":\"HRA-RL\"}\nfig,axes=plt.subplots(1,3,figsize=(18,5)); fig.suptitle(\"Training Reward Curves — 8 Seeds\",fontsize=13,fontweight=\"bold\")\nfor ax,(agent,colour) in zip(axes,COLOURS.items()):\n    logs=train_logs.get(agent,[])\n    if not logs: ax.set_title(f\"{LABELS[agent]}\\n(no data)\"); continue\n    allr=[]\n    for df in logs: ax.plot(df[\"step\"],df[\"reward_mean\"],alpha=0.3,lw=0.8,color=colour); allr.append(df[\"reward_mean\"].values)\n    ml=max(len(r) for r in allr); pad=np.array([np.pad(r,(0,ml-len(r)),constant_values=np.nan) for r in allr])\n    mean=np.nanmean(pad,axis=0); sd=np.nanstd(pad,axis=0); steps=np.linspace(CFG[\"LOG_EVERY\"],CFG[\"PPO_STEPS\"],ml)\n    ax.plot(steps,mean,lw=2.5,color=colour,ls=\"--\",zorder=5); ax.fill_between(steps,mean-sd,mean+sd,alpha=0.15,color=colour)\n    ax.set_title(LABELS[agent],fontweight=\"bold\"); ax.set_xlabel(\"Step\"); ax.set_ylabel(\"Mean Reward\")\nplt.tight_layout(); p=os.path.join(WORK_DIR,\"training_curves.png\")\nplt.savefig(p,dpi=150,bbox_inches=\"tight\",facecolor=\"white\"); plt.show(); print(f\"Saved: {p}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"a1eec950-ec43-48cf-8ec3-fc583745badd","cell_type":"code","source":"# CELL 17 — SRIP Gradient Variance\nimport matplotlib.pyplot as plt, matplotlib.gridspec as gridspec, pandas as pd, numpy as np, os\nCOLOURS={\"reinforce\":\"#C0392B\",\"ppo_clip\":\"#E67E22\",\"hra\":\"#1B6B7B\"}\nLABELS={\"reinforce\":\"Std REINFORCE\",\"ppo_clip\":\"PPO-Clip\",\"hra\":\"HRA-RL\"}\nfig=plt.figure(figsize=(18,11)); gs=gridspec.GridSpec(2,3,figure=fig,hspace=0.4,wspace=0.35)\nfor col,(agent,colour) in enumerate(COLOURS.items()):\n    ax=fig.add_subplot(gs[0,col]); dfs=grad_store.get(agent,[])\n    if not dfs: ax.set_title(f\"{LABELS[agent]}\\n(no data)\"); continue\n    for g in dfs: ax.plot(g[\"step\"],g[\"clipped_norm\"],alpha=0.3,lw=0.6,color=colour)\n    c=pd.concat(dfs); mn=c.groupby(\"step\")[\"clipped_norm\"].mean()\n    ax.plot(mn.index,mn.values,lw=2,color=colour,ls=\"--\"); ax.set_title(LABELS[agent],fontweight=\"bold\")\n    ax.set_xlabel(\"Step\"); ax.set_ylabel(\"Grad Norm\")\nax4=fig.add_subplot(gs[1,0])\nfor agent,colour in COLOURS.items():\n    dfs=grad_store.get(agent,[])\n    if not dfs: continue\n    c=pd.concat(dfs); v=c.groupby(\"step\")[\"clipped_norm\"].std(); ax4.plot(v.index,v.values,color=colour,lw=2,label=LABELS[agent])\nax4.set_title(\"SRIP: Grad Norm SD Across Seeds\",fontweight=\"bold\"); ax4.legend(fontsize=7)\nax5=fig.add_subplot(gs[1,1]); bd,bl,bc=[],[],[]\nfor agent,colour in COLOURS.items():\n    dfs=grad_store.get(agent,[])\n    if not dfs: continue\n    bd.append([g[\"clipped_norm\"].std() for g in dfs]); bl.append(LABELS[agent]); bc.append(colour)\nif bd:\n    bp=ax5.boxplot(bd,patch_artist=True,labels=bl)\n    for pt,c in zip(bp[\"boxes\"],bc): pt.set_facecolor(c); pt.set_alpha(0.7)\nax5.set_title(\"Per-Seed Grad Norm SD\",fontweight=\"bold\")\nax6=fig.add_subplot(gs[1,2])\nfor agent,colour in COLOURS.items():\n    dfs=grad_store.get(agent,[]); rl=results[\"scienceqa\"].get(agent,[])\n    if not dfs or not rl: continue\n    tsr=[r.get(\"Task_Success_Rate\",0) for r in rl]; gsd=[g[\"clipped_norm\"].std() for g in dfs]; mn=min(len(tsr),len(gsd))\n    ax6.scatter(gsd[:mn],tsr[:mn],color=colour,s=50,alpha=0.8,label=LABELS[agent])\nax6.set_title(\"Grad Variance vs TSR\",fontweight=\"bold\"); ax6.legend(fontsize=6)\nfig.suptitle(\"Sparse Reward-Induced Policy Instability (SRIP)\",fontsize=13,fontweight=\"bold\",y=0.99)\np=os.path.join(WORK_DIR,\"srip_analysis.png\"); plt.savefig(p,dpi=150,bbox_inches=\"tight\",facecolor=\"white\"); plt.show(); print(f\"Saved: {p}\")\n","metadata":{},"outputs":[],"execution_count":null},{"id":"0ce6c425-f979-4001-a5b7-4b3b8167b076","cell_type":"code","source":"# CELL 18 — Save All Results\nimport pandas as pd, os, json as _json\nrows=[r for b in results for a in results[b] for r in results[b][a]]\ndf=pd.DataFrame(rows); p=os.path.join(WORK_DIR,\"all_results_FINAL.csv\"); df.to_csv(p,index=False)\nprint(f\"Saved: {p}\\n\")\nfor bm in results:\n    sub=df[df.benchmark==bm]\n    if sub.empty: continue\n    cols=[c for c in [\"Task_Success_Rate\",\"Hallucination_Rate\",\"POPE_Accuracy\",\"POPE_F1\"] if c in sub.columns]\n    print(f\"\\n{bm.upper()}:\"); print(sub.groupby(\"agent\")[cols].mean().round(4).to_string())\nprint(\"\\nFiles to download: all_results_FINAL.csv, conformal_results.json,\")\nprint(\"conformal_coverage.png, training_curves.png, srip_analysis.png\")\n","metadata":{},"outputs":[],"execution_count":null}]}