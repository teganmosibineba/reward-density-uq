)/max(1,tp+fp+tn+fn); prec=tp/max(1,tp+fp); rec=tp/max(1,tp+fn)\n        f1=2*prec*rec/max(1e-9,prec+rec)\n        return {\"POPE_Accuracy\":round(acc,4),\"POPE_F1\":round(f1,4),\n                \"Hallucination_Rate\":round(fp/max(1,fp+tn),4),\"n\":len(responses)}\n    scores,hits,em=[],[],[]\n    for resp,gt in zip(responses,ground_truths):\n        s=fgm_score(resp,gt); scores.append(s)\n        hits.append(1 if s>=CFG[\"FGM_THRESHOLD\"] else 0)\n        em.append(1 if gt.lower().strip() in resp.lower() else 0)\n    return {\"Task_Success_Rate\":round(np.mean(hits),4),\n            \"Semantic_Consistency_Score\":round(np.mean(scores),4),\n            \"Hallucination_Rate\":round(1-np.mean(hits),4),\n            \"Exact_Match_Accuracy\":round(np.mean(em),4),\n            \"Mean_FGM_Score\":round(np.mean(scores),4),\"n\":len(responses)}\n\ndef get_fgm_scores(responses, ground_truths):\n    # Returns raw FGM scores for conformal prediction (nonconformity = 1 - fgm)\n    return [fgm_score(r,g) for r,g in zip(responses,ground_truths)]\n\ndef ci95(values):\n    n=len(values)\n    if n<2: return (float(values[0]) if n==1 else 0,0)\n    m,se=np.mean(values),scipy_stats.sem(values)\n    t=scipy_stats.t.ppf(0.975,df=n-1)\n    return round(m-t*se,4),round(m+t*se,4)\nprint(\"Metrics + conformal scoring ready.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T04:15:38.111277Z","iopub.execute_input":"2026-06-29T04:15:38.111782Z","iopub.status.idle":"2026-06-29T04:15:38.124134Z","shell.execute_reply.started":"2026-06-29T04:15:38.111743Z","shell.execute_reply":"2026-06-29T04:15:38.123177Z"}},"outputs":[{"name":"stdout","text":"Metrics + conformal scoring ready.\n","output_type":"stream"}],"execution_count":9},{"id":"5f3b1b08-f39a-4c92-a231-7cef20d89dc2","cell_type":"code","source":"# CELL 10 — Training Loop\nimport torch, numpy as np, pandas as pd\ndef run_training(model,config_name,questions,seed=42,n_steps=None,use_ppo_clip=False):\n    if n_steps is None: n_steps=CFG[\"PPO_STEPS\"]\n    set_seed(seed)\n    opt=torch.optim.AdamW([p for p in model.parameters() if p.requires_grad],lr=CFG[\"LEARNING_RATE\"],weight_decay=0.01)\n    baseline=0.0; eps=CFG[\"PPO_EPSILON\"]; algo=\"PPO-Clip\" if use_ppo_clip else \"REINFORCE\"\n    reward_log,grad_log=[],[]; wr,wf,wt=[],[],[]\n    print(f\"\\n{'='*58}\\n[{config_name}] [{algo}] seed={seed} steps={n_steps}\\n{'='*58}\")\n    for step in range(n_steps):\n        q=questions[step%len(questions)]\n        prompt=f\"USER: <image>\\n{q['prompt']}\\nASSISTANT:\"\n        inputs=processor(text=prompt,images=q[\"image\"],return_tensors=\"pt\").to(\"cuda\")\n        with torch.no_grad():\n            gen=model.generate(**inputs,max_new_tokens=CFG[\"MAX_NEW_TOKENS\"],do_sample=True,\n                temperature=CFG[\"TEMPERATURE\"],pad_token_id=processor.tokenizer.eos_token_id)\n        new=gen[0][inputs.input_ids.shape[1]:]; resp=processor.decode(new,skip_special_tokens=True)\n        fs=fgm_score(resp,q[\"ground_truth\"]); reward=compute_reward(config_name,fs)\n        adv=reward-baseline; baseline=CFG[\"EMA_DECAY\"]*baseline+(1-CFG[\"EMA_DECAY\"])*reward\n        seq=torch.cat([inputs.input_ids,new.unsqueeze(0)],dim=1)\n        lab=seq.clone(); lab[:,:inputs.input_ids.shape[1]]=-100\n        out=model(input_ids=seq,attention_mask=torch.ones_like(seq),labels=lab); lp=-out.loss\n        advt=torch.tensor(adv,dtype=torch.float32,device=lp.device)\n        if use_ppo_clip:\n            with torch.no_grad():\n                old=model(input_ids=seq,attention_mask=torch.ones_like(seq),labels=lab); olp=-old.loss.detach()\n            ratio=torch.exp(lp-olp); clip=torch.clamp(ratio,1-eps,1+eps); loss=-torch.min(ratio*advt,clip*advt)\n        else: loss=-lp*advt\n        opt.zero_grad(); loss.backward()\n        rg=sum(p.grad.data.norm(2).item()**2 for p in model.parameters() if p.grad is not None)**0.5\n        cg=torch.nn.utils.clip_grad_norm_(model.parameters(),CFG[\"GRAD_CLIP\"]).item(); opt.step()\n        wr.append(reward); wf.append(fs); wt.append(float(fs>CFG[\"TASK_THRESHOLD\"]))\n        grad_log.append({\"step\":step+1,\"raw_grad_norm\":rg,\"clipped_norm\":cg,\"reward\":reward,\"advantage\":adv,\"fgm\":fs})\n        if (step+1)%CFG[\"LOG_EVERY\"]==0:\n            k=CFG[\"LOG_EVERY\"]; rm=np.mean(wr[-k:]); fm=np.mean(wf[-k:]); tsr=np.mean(wt[-k:])\n            gn=np.mean([g[\"clipped_norm\"] for g in grad_log[-k:]])\n            print(f\"  Step {step+1:4d}/{n_steps} | R={rm:+.3f} | FGM={fm:.3f} | TSR={tsr:.3f} | Grad={gn:.3f}\")\n            reward_log.append({\"step\":step+1,\"reward_mean\":rm,\"fgm_mean\":fm,\"tsr\":tsr,\"grad_norm\":gn,\n                               \"config\":config_name,\"seed\":seed,\"algo\":algo})\n    print(f\"  Done. Mean R={np.mean(wr):.4f}\")\n    s_df=pd.DataFrame(reward_log); g_df=pd.DataFrame(grad_log)\n    g_df[\"config\"]=config_name; g_df[\"seed\"]=seed; g_df[\"algo\"]=algo\n    return s_df,g_df\nprint(\"run_training ready.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T04:15:43.012897Z","iopub.execute_input":"2026-06-29T04:15:43.013608Z","iopub.status.idle":"2026-06-29T04:15:43.028322Z","shell.execute_reply.started":"2026-06-29T04:15:43.013579Z","shell.execute_reply":"2026-06-29T04:15:43.027431Z"}},"outputs":[{"name":"stdout","text":"run_training ready.\n","output_type":"stream"}],"execution_count":10},{"id":"6fbc508d-a55e-4849-85dc-19163fb67b70","cell_type":"code","source":"# CELL 11 — Evaluation Loop (stores responses for conformal prediction)\nimport torch\ndef run_evaluation(label,model,questions,seed=42,log_interval=200):\n    set_seed(seed); responses,gts=[],[]\n    print(f\"Eval [{label}] n={len(questions)}\")\n    for i,q in enumerate(questions):\n        prompt=f\"USER: <image>\\n{q['prompt']}\\nASSISTANT:\"\n        inputs=processor(text=prompt,images=q[\"image\"],return_tensors=\"pt\").to(\"cuda\")\n        with torch.no_grad():\n            gen=model.genera