ELL 12 — Multi-Seed Experiment (3 benchmarks, validation pass)\nimport os, gc, json as _json\n\nBENCHES=[\"scienceqa\",\"vqa_v2\",\"pope\"]   # matches CFG[\"BENCHES\"]\nTESTSETS={\"scienceqa\":SCIQA_TEST,\"vqa_v2\":VQA_TEST,\"pope\":POPE_TEST}\nSOURCES={\"scienceqa\":\"generic\",\"vqa_v2\":\"generic\",\"pope\":\"pope\"}\n\nresults={b:{\"reinforce\":[],\"ppo_clip\":[],\"hra\":[],\"vanilla\":[]} for b in BENCHES}\ngrad_store={\"reinforce\":[],\"ppo_clip\":[],\"hra\":[]}\ntrain_logs={\"reinforce\":[],\"ppo_clip\":[],\"hra\":[]}\nconformal_scores={b:{\"reinforce\":{},\"ppo_clip\":{},\"hra\":{},\"vanilla\":{}} for b in BENCHES}\ncompleted=[]\n\ntry:\n    cks=sorted([f for f in os.listdir(WORK_DIR) if f.startswith(\"ckpt_seed\") and f.endswith(\".json\")],\n               key=lambda x: os.path.getmtime(os.path.join(WORK_DIR,x)))\n    if cks:\n        with open(os.path.join(WORK_DIR,cks[-1])) as f: completed=_json.load(f).get(\"completed\",[])\n        print(f\"Resuming. Completed: {completed}\")\nexcept Exception as e: print(f\"No checkpoint: {e}\")\n\nto_run=[s for s in CFG[\"SEEDS\"] if s not in completed]\nprint(f\"Seeds to run: {to_run}\")\n\nfor seed in to_run:\n    print(f\"\\n{'-'*50}\\n  SEED {seed}\\n{'-'*50}\")\n    TRAIN_SQ=build_scienceqa(\"train\",CFG[\"TRAIN_ITEMS\"],seed)\n    for agent,cfg_name,clip in [(\"reinforce\",\"E: Std REINFORCE\",False),\n                                 (\"ppo_clip\",\"E: Std REINFORCE\",True),\n                                 (\"hra\",\"D: Full HRA\",False)]:\n        nuke(); algo=\"PPO-Clip\" if clip else \"REINFORCE\"\n        print(f\"\\n  [{algo}] seed={seed}\")\n        m=make_lora_model()\n        s_df,g_df=run_training(m,cfg_name,TRAIN_SQ,seed=seed,use_ppo_clip=clip)\n        g_df[\"agent\"]=agent; grad_store[agent].append(g_df); train_logs[agent].append(s_df)\n        for bm in BENCHES:\n            ts=TESTSETS[bm]\n            if not ts: continue\n            r,gt=run_evaluation(f\"{agent}-{bm}\",m,ts,seed=42)\n            met=compute_metrics(r,gt,source=SOURCES[bm])\n            met.update({\"seed\":seed,\"agent\":agent,\"benchmark\":bm,\"algo\":algo})\n            results[bm][agent].append(met)\n            if SOURCES[bm]==\"generic\":\n                conformal_scores[bm][agent][seed]=get_fgm_scores(r,gt)\n        nuke()\n    nuke(); print(f\"\\n  [Vanilla] seed={seed}\")\n    vm=make_vanilla_model()\n    for bm in BENCHES:\n        ts=TESTSETS[bm]\n        if not ts: continue\n        r,gt=run_evaluation(f\"Vanilla-{bm}\",vm,ts,seed=42)\n        met=compute_metrics(r,gt,source=SOURCES[bm])\n        met.update({\"seed\":seed,\"agent\":\"vanilla\",\"benchmark\":bm,\"algo\":\"none\"})\n        results[bm][\"vanilla\"].append(met)\n        if SOURCES[bm]==\"generic\":\n            conformal_scores[bm][\"vanilla\"][seed]=get_fgm_scores(r,gt)\n    nuke()\n    completed.append(seed)\n    with open(os.path.join(WORK_DIR,f\"ckpt_seed{seed}.json\"),\"w\") as f:\n        _json.dump({\"completed\":completed},f)\n    import pickle\n    with open(os.path.join(WORK_DIR,\"conformal_scores.pkl\"),\"wb\") as f:\n        pickle.dump(conformal_scores,f)\n    rows=[r for b in results for a in results[b] for r in results[b][a]]\n    pd.DataFrame(rows).to_csv(os.path.join(WORK_DIR,\"all_results_live.csv\"),index=False)\n    print(f\"  Checkpoint + conformal scores + CSV saved. [seed {seed} done, {len(completed)}/{len(CFG['SEEDS'])} total]\")\n    del TRAIN_SQ; gc.collect()\n\nprint(\"\\nAll seeds complete.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-19T15:19:48.056372Z","iopub.execute_input":"2026-07-19T15:19:48.056634Z","iopub.status.idle":"2026-07-19T15:19:48.10716Z","shell.execute_reply.started":"2026-07-19T15:19:48.056612Z","shell.execute_reply":"2026-07-19T15:19:48.106532Z"}},"outputs":[{"name":"stdout","text":"\n==================================================================\nCONFORMAL COVERAGE DIAGNOSTIC  (target = 90%)\n==================================================================\n\nSCIENCEQA\n  Agent         Coverage      Gap   CovStd  Status\n  vanilla         0.9175  +0.0175   0.0580  well-calibrated\n  reinforce       0.9375  +0.0375   0.0406  well-calibrated\n  ppo_clip        0.9325  +0.0325   0.0501  well-calibrated\n  hra             0.9350  +0.0350   0.0382  well-calibrated\n\nVQA_V2\n  Agent         Coverage      Gap   CovStd  Status\n  vanilla         0.9400  +0.0400   0.0466  well-calibrated\n  reinforce       0.9000  -0.0000   0.0566  well-calibrated\n  ppo_clip        0.9050  +0.0050   0.0553  well-calibrated\n  hra             0.9125  +0.0125   0.0565  well-calibrated\n\n==================================================================\nICLR HEADLINE READ\n==================================================================\n  scienceqa    HRA gap=+0.035 (std 0.038) | REINFORCE gap=+0.037 (std 0.041) | HRA better\n  vqa_v2       HRA gap=+0.013 (std 0.057) | REINFORCE gap=-0.000 (std 0.057) | REINFORCE better\n\n  HRA better-calibrated on 1/2 benchmarks.\n  >>> MIXED: partial advantage. Needs the full 5-benchmark run to confirm.\n\nSaved conformal_diagnostic.json\n","output_type":"stream"}],"execution_count":16},{"cell_type":"code","source":"# ============================================================\n# EFFICIENCY DIAGNOSTIC — run AFTER CONFORMAL_DIAGNOSTIC.py\n# This is the metric that actually distinguishes agents when\n# coverage alone looks similar across the board (as yours does).\n# ============================================================\nimport numpy as np\n\nALPHA = CFG[\"CONFORMAL_ALPHA\"]\nAGENTS = [\"vanilla\",\"reinforce\",\"ppo_clip\",\"hra\"]\nLABELS = {\"vanilla\":\"Vanilla\",\"reinforce\":\"REINFORCE\",\"ppo_clip\":\"PPO-Clip\",\"hra\":\"HRA-RL\"}\n\ndef split_conformal_full(scores, alpha=0.1, cal_frac=0.5, seed=0):\n    s = np.array([1.0 - x for x in scores]); n = len(s)\n    if n < 10: return None\n    rng = np.random.default_rng(seed); idx = rng.permutation(n)\n    ncal = int(n*cal_frac)\n    cal, test = s[idx[:ncal]], s[idx[ncal:]]\n    qlev = min(np.ceil((ncal+1)*(1-alpha))/ncal, 1.0)\n    qhat = np.quantile(cal, qlev, method=\"higher\")\n    coverage = float(np.mean(test <= qhat))\n    # Efficiency: how tight is the acceptance region? Smaller qhat = smaller\n    # nonconformity budget = agent's typical response is closer to ground\n    # truth, i.e. sharper / more confident correct predictions.\n    return {\"coverage\":coverage, \"qhat\":float(qhat), \"gap\":coverage-(1-alpha)}\n\nprint(f\"{'='*70}\\nEFFICIENCY (qhat / nonconformity budget) — lower = better calibrated agent\\n{'='*70}\")\neff_summary = {}\nfor bm in conformal_scores:\n    agents_here = {a:s for a,s in conformal_scores[bm].items() if s}\n    if not agents_here: continue\n    print(f\"\\n{bm.upper()}\")\n    print(f\"  {'Agent':<12}{'Coverage':>10}{'q_hat':>9}   (q_hat = nonconformity threshold; smaller = tighter/better)\")\n    eff_summary[bm] = {}\n    for ag in AGENTS:\n        seed_scores = conformal_scores[bm].get(ag, {})\n        if not seed_scores: continue\n        qhats, covs = [], []\n        for sd, sc in seed_scores.items():\n            r = split_conformal_full(sc, alpha=ALPHA, seed=int(sd) if str(sd).isdigit() else 0)\n            if r: qhats.append(r[\"qhat\"]); covs.append(r[\"coverage\"])\n        if not qhats: continue\n        mq, mc = np.mean(qhats), np.mean(covs)\n        eff_summary[bm][ag] = {\"qhat_mean\": round(mq,4), \"coverage_mean\": round(mc,4)}\n        print(f\"  {ag:<12}{mc:>10.4f}{mq:>9.4f}\")\n\nprint(f\"\\n{'='*70}\\nEFFICIENCY HEADLINE READ\\n{'='*70}\")\nwins, total = 0, 0\nfor bm, ags in eff_summary.items():\n    if \"hra\" in ags and \"reinforce\" in ags:\n        total += 1\n        better = ags[\"hra\"][\"qhat_mean\"] < ags[\"reinforce\"][\"qhat_mean\"]\n        if better: wins += 1\n        pct = (1 - ags[\"hra\"][\"qhat_mean\"]/ags[\"reinforce\"][\"qhat_mean\"]) * 100 if ags[\"reinforce\"][\"qhat_mean\"] else 0\n        pri